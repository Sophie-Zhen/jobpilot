+// ── Patched (jobpilot fork): human-like engagement helpers ────────────
+// Upstream linkedin search does page.goto + Voyager API call with no scroll,
+// no dwell, no inter-call jitter. That pattern is trivially classifiable by
+// LinkedIn's anti-bot system. These helpers add the behavioral signals
+// (think-time, scrolling, reading dwell) that a real human exhibits while
+// browsing job listings. Patched via patch-package; see patches/ in jobpilot.
+async function _humanJitter(minMs, maxMs) {
+    const ms = Math.floor(Math.random() * Math.max(0, maxMs - minMs)) + minMs;
+    return new Promise((resolve) => setTimeout(resolve, ms));
+}
+async function _humanBrowseResults(page) {
+    // Initial "load and look" pause before any interaction
+    await _humanJitter(1500, 3500);
+    // Scroll the results page 2-4 times, simulating scanning the listings
+    const scrolls = 2 + Math.floor(Math.random() * 3);
+    for (let i = 0; i < scrolls; i++) {
+        try {
+            await page.autoScroll({ times: 1, delayMs: 600 + Math.floor(Math.random() * 800) });
+        }
+        catch (_) {
+            // autoScroll may be unavailable on some adapter builds — non-fatal
+        }
+        await _humanJitter(1500, 4000);
+    }
+    // Settle pause before extraction
+    await _humanJitter(1000, 3000);
+}
+async function _humanDwellOnDetail(page) {
+    // Initial pause after navigation completes — "looking at the page"
+    await _humanJitter(2000, 5000);
+    // Scroll through the JD as if reading
+    const scrolls = 2 + Math.floor(Math.random() * 2);
+    for (let i = 0; i < scrolls; i++) {
+        try {
+            await page.autoScroll({ times: 1, delayMs: 700 + Math.floor(Math.random() * 600) });
+        }
+        catch (_) { }
+        await _humanJitter(1500, 3500);
+    }
+}
